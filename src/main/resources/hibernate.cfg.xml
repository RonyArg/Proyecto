<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 4.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-4.0.dtd">

<hibernate-configuration>


    <session-factory>

        <!-- Configuración para la conexión con la base de datos SQLite -->
        <property name="hibernate.connection.driver_class">org.sqlite.JDBC</property>
        <property name="hibernate.connection.url">jdbc:sqlite:recetas.db</property>
        <property name="hibernate.connection.username"></property>
        <property name="hibernate.connection.password"></property>
        
        <!-- Configuración que crea tablas si no existen, muestra las consultas sql en consolagit -->
        <property name="hibernate.hbm2ddl.auto">create</property>
        <property name="hibernate.show_sql">true</property>
        <property name="current_session_context_class">thread</property>
        <property name="hibernate.dialect">org.hibernate.community.dialect.SQLiteDialect</property>

        <!-- Clase Java que mapea y establece la conexión -->
        <mapping class="es.proyecto.model.Receta"/>

    </session-factory>

</hibernate-configuration>